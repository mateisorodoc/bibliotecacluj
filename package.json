{
  "name": "bcu-library-platform",
  "version": "1.0.0",
  "description": "BCU digital library platform with authentication and admin panel",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build": "npm run build:newapp",
    "build:newapp": "npm --prefix newapp run build",
    "dev:newapp": "npm --prefix newapp run dev"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-html-parser": "^7.1.0",
    "nodemailer": "^8.0.5"
  }
}
